# ──────────────────────────────────────────
# Astral Agent — Environment Variables
# Solo necesitás esta key para correr el backend
# ──────────────────────────────────────────

# OpenAI API key (platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Server port (opcional, default 3000)
PORT=3000

# Local asset storage fallback for development when R2_* is not configured.
ASSET_STORAGE_DIR=.local-assets

# SuperTokens managed auth surface.
# En dev con Vite proxy, el public-facing origin sigue siendo 5173.
SUPERTOKENS_CONNECTION_URI=https://try.supertokens.com
SUPERTOKENS_API_KEY=
SUPERTOKENS_APP_NAME="Astral Guide"
SUPERTOKENS_API_DOMAIN=http://localhost:5173
SUPERTOKENS_WEBSITE_DOMAIN=http://localhost:5173
SUPERTOKENS_API_BASE_PATH=/auth
SUPERTOKENS_WEBSITE_BASE_PATH=/auth
SUPERTOKENS_DASHBOARD_API_KEY=

# Optional: branded passwordless emails via your own SMTP provider.
# If you set any of these, provide the full set required below.
SUPERTOKENS_SMTP_HOST=
SUPERTOKENS_SMTP_PORT=
SUPERTOKENS_SMTP_USERNAME=
SUPERTOKENS_SMTP_PASSWORD=
SUPERTOKENS_SMTP_SECURE=false
SUPERTOKENS_EMAIL_FROM=
SUPERTOKENS_EMAIL_FROM_NAME="Astral Guide"
SUPERTOKENS_EMAIL_SUPPORT_HREF=mailto:hello@astral.guide?subject=Astral%20Guide%20Support
