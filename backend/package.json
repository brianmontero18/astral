{
  "name": "astral-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env --import tsx/esm src/server.ts",
    "start": "node --env-file=.env dist/server.js",
    "seed:local": "node --env-file=.env --import tsx/esm scripts/seed-local.ts",
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@fastify/cors": "^10.0.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^9.0.0",
    "@libsql/client": "^0.17.0",
    "@react-pdf/renderer": "^4.3.2",
    "@types/node": "^22.15.3",
    "@types/react": "^19.2.14",
    "fastify": "^5.3.2",
    "pdfjs-dist": "^4.0.379",
    "supertokens-node": "^24.0.2",
    "swisseph-wasm": "^0.0.4",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  },
  "optionalDependencies": {
    "@esbuild/darwin-arm64": "^0.27.3",
    "@libsql/darwin-arm64": "^0.5.22"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  }
}
